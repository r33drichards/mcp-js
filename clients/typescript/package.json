{
  "name": "@mcp-v8/client",
  "version": "0.1.0",
  "description": "TypeScript client for the mcp-v8 JavaScript execution server, generated from the OpenAPI spec.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/r33drichards/mcp-js"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema.d.ts"
  },
  "files": [
    "src"
  ],
  "scripts": {
    "generate": "openapi-typescript ../../openapi.json --output ./src/schema.d.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "openapi-fetch": "^0.13.4"
  },
  "devDependencies": {
    "openapi-typescript": "^7.5.0",
    "typescript": "^5.6.0"
  }
}
